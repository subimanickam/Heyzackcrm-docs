# HeyZack Partner Portal docs — sibling CRM docs URLs
# Copy to .env.local and adjust. NEXT_PUBLIC_* is inlined at build time.

# Which site this build is: `partner` (default here) or `crm`
# NEXT_PUBLIC_DOCS_SITE=partner

# Full URL to the Partner Portal documentation (this app)
# Local default if unset: http://localhost:3000/docs
# NEXT_PUBLIC_PARTNER_DOCS_URL=https://partner-docs.example.com/docs

# Full URL to the CRM documentation app
# Local default if unset: http://localhost:3001/docs
# NEXT_PUBLIC_CRM_DOCS_URL=https://crm-docs.example.com/docs
