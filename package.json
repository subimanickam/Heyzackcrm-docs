{
  "name": "heyzack-documents",
  "version": "1.0.0",
  "private": true,
  "description": "HeyZack documentation monorepo: Partner and CRM docs in one Next.js app (single host)",
  "workspaces": [
    "apps/partner-docs"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@heyzack/partner-docs",
    "dev:partner": "npm run dev --workspace=@heyzack/partner-docs",
    "build": "npm run build --workspace=@heyzack/partner-docs",
    "build:partner": "npm run build --workspace=@heyzack/partner-docs",
    "start": "npm run start --workspace=@heyzack/partner-docs",
    "start:partner": "npm run start --workspace=@heyzack/partner-docs",
    "lint": "npm run lint --workspace=@heyzack/partner-docs",
    "test": "npm run test --workspace=@heyzack/partner-docs"
  },
  "engines": {
    "node": ">=18"
  }
}
