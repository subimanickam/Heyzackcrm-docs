{
  "name": "heyzack-documents",
  "version": "1.0.0",
  "private": true,
  "description": "HeyZack documentation monorepo: Partner Portal docs and CRM docs (single codebase)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:crm",
    "dev:crm": "npm run dev --workspace=@heyzack/crm-docs",
    "dev:partner": "npm run dev --workspace=@heyzack/partner-docs",
    "build": "npm run build --workspaces --if-present",
    "build:crm": "npm run build --workspace=@heyzack/crm-docs",
    "build:partner": "npm run build --workspace=@heyzack/partner-docs",
    "start:crm": "npm run start --workspace=@heyzack/crm-docs",
    "start:partner": "npm run start --workspace=@heyzack/partner-docs",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  }
}
